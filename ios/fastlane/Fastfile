# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # 0. Setup CI environment (creates a temporary keychain on CI runners)
    setup_ci if ENV['CI']

    # 1. Sync certificates and profiles
    match(type: "appstore", readonly: is_ci)
    
    # 2. Ensure Pods are up to date
    cocoapods
    
    # 3. Increment build number
    increment_build_number(xcodeproj: "Runner.xcodeproj")
    
    # 4. Build the app for App Store distribution
    build_app(
      workspace: "Runner.xcworkspace", 
      scheme: "Runner",
      export_method: "app-store",
      clean: true,
      xcargs: "CODE_SIGN_STYLE=Manual " \
              "PROVISIONING_PROFILE_SPECIFIER='match AppStore com.deepblue.turathy' " \
              "CODE_SIGN_IDENTITY='Apple Distribution' " \
              "DEVELOPMENT_TEAM='N6P5KD4Z98'",
      export_options: {
        provisioningProfiles: {
          "com.deepblue.turathy" => "match AppStore com.deepblue.turathy"
        }
      }
    )
    
    # 5. Upload to TestFlight
    upload_to_testflight
  end
end
