# This file contains the fastlane.tools configuration
# You can find the documentation at https://docs.fastlane.tools
#
# For a list of all available actions, check out
#
#     https://docs.fastlane.tools/actions
#
# For a list of all available plugins, check out
#
#     https://docs.fastlane.tools/plugins/available-plugins
#

# Uncomment the line if you want fastlane to automatically update itself
# update_fastlane

default_platform(:ios)

platform :ios do
  desc "Push a new beta build to TestFlight"
  lane :beta do
    # 0. Setup CI environment (creates a temporary keychain on CI runners)
    setup_ci if ENV['CI']

    # 1. Sync certificates and profiles
    match(type: "appstore", readonly: is_ci)
    
    # 2. Ensure Pods are up to date
    cocoapods
    
    # 3. Increment build number based on the latest build on App Store Connect
    latest_build = latest_testflight_build_number(
      app_identifier: "com.deepblue.turathy",
      initial_build_number: 0
    )
    increment_build_number(
      xcodeproj: "Runner.xcodeproj",
      build_number: latest_build + 1
    )
    
    # 4. Disable automatic signing ONLY for the Runner target (not Pods)
    update_code_signing_settings(
      use_automatic_signing: false,
      path: "Runner.xcodeproj",
      targets: ["Runner"],
      team_id: "N6P5KD4Z98",
      code_sign_identity: "Apple Distribution",
      profile_name: "match AppStore com.deepblue.turathy"
    )

    # 5. Archive only (skip IPA export — we need to patch App.framework first)
    build_app(
      workspace: "Runner.xcworkspace",
      scheme: "Runner",
      skip_package_ipa: true,
      clean: true
    )

    # 6. Patch App.framework/Info.plist — known Flutter bug: MinimumOSVersion is empty
    archive_path = lane_context[SharedValues::XCODEBUILD_ARCHIVE]
    app_plist = "#{archive_path}/Products/Applications/Runner.app/Frameworks/App.framework/Info.plist"
    if File.exist?(app_plist)
      sh("plutil -replace MinimumOSVersion -string '13.0' \"#{app_plist}\" 2>/dev/null || plutil -insert MinimumOSVersion -string '13.0' \"#{app_plist}\"")
      UI.success("✅ Patched App.framework/Info.plist with MinimumOSVersion=13.0")
    else
      UI.important("⚠️  App.framework/Info.plist not found at #{app_plist}")
    end

    # 7. Export the patched archive into an IPA
    ipa_output_dir = File.expand_path("../build", Dir.pwd)
    sh("xcodebuild -exportArchive " \
       "-archivePath \"#{archive_path}\" " \
       "-exportPath \"#{ipa_output_dir}\" " \
       "-exportOptionsPlist \"#{File.expand_path('ExportOptions.plist', Dir.pwd)}\"")
    exported_ipa = Dir.glob("#{ipa_output_dir}/*.ipa").first
    lane_context[SharedValues::IPA_OUTPUT_PATH] = exported_ipa
    
    # 8. Upload the IPA to TestFlight
    upload_to_testflight(ipa: lane_context[SharedValues::IPA_OUTPUT_PATH])
  end
end
